<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Main app theme (no action bar) -->
    <style name="Theme.ScriptHub" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- Splash screen theme (Android 12+ SplashScreen API) -->
    <style name="Theme.ScriptHub.Splash" parent="Theme.SplashScreen">
        <!-- Splash background color — matches app dark background -->
        <item name="windowSplashScreenBackground">#0F201A</item>
        <!-- The animated icon shown in the center -->
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_icon</item>
        <!-- Icon background (circle behind the icon) — subtle dark teal -->
        <item name="windowSplashScreenIconBackgroundColor">#1A2E26</item>
        <!-- After splash, transition to the main theme -->
        <item name="postSplashScreenTheme">@style/Theme.ScriptHub</item>
    </style>

</resources>
