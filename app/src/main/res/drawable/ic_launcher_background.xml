<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Deep navy background gradient -->
    <path android:pathData="M0,0 L108,0 L108,108 L0,108 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:startX="0"
                android:startY="0"
                android:endX="108"
                android:endY="108"
                android:type="linear">
                <item android:offset="0.0" android:color="#FF0D1B3E" />
                <item android:offset="1.0" android:color="#FF061020" />
            </gradient>
        </aapt:attr>
    </path>

    <!-- Subtle radial glow at center -->
    <path android:pathData="M54,54 m-45,0 a45,45 0 1,0 90,0 a45,45 0 1,0 -90,0">
        <aapt:attr name="android:fillColor">
            <gradient
                android:centerX="54"
                android:centerY="54"
                android:gradientRadius="45"
                android:type="radial">
                <item android:offset="0.0" android:color="#1A4A90E2" />
                <item android:offset="1.0" android:color="#004A90E2" />
            </gradient>
        </aapt:attr>
    </path>
</vector>
